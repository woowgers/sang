
{
	"version": "0.0.6",
	"description": "Sang is not GRUB",
	"url": "https://github.com/woowgers/sang/archive/refs/tags/0.0.6.zip",
	"homepage": "https://github.com/woowgers/sang",
	"license": "WTFPL",
	"extract_dir": "sang-0.0.6",
	"hash": "061d33b37697c7d268229324273f5387877775c32052a52856f86bf6970a916b",
	"shortcuts": [
		[
			"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
			"Sang",
			"-WindowStyle Hidden -Command \"nu $dir\\sang.nu\"",
			"icons\\sang-boot-512.ico"
		]
	],
	"depends": [
		"jq",
		"jc",
		"nu",
		"gsudo",
		"https://ncruces.github.io/scoop/zenity.json"
	],
	"post_install": [
	    "$jcParserDir = \"$env:LOCALAPPDATA\\jc\\jc\\jcparsers\"",
	    "if (-not (Test-Path $jcParserDir)) { New-Item -ItemType Directory -Force -Path $jcParserDir | Out-Null }",
	    "Copy-Item -Path \"$dir\\misc\\bcdedit.py\" -Destination \"$jcParserDir\\bcdedit.py\" -Force",
	    "Write-Host \"Installed jc parser to $jcParserDir\\bcdedit.py\" -ForegroundColor Green"
	],
	"pre_uninstall": [
	    "$jcParserFile = \"$env:LOCALAPPDATA\\jc\\jc\\jcparsers\\bcdedit.py\"",
	    "if (Test-Path $jcParserFile) { Remove-Item $jcParserFile -Force }",
	    "$cacheDir = \"$env:LOCALAPPDATA\\jc\\jc\\jcparsers\\__pycache__\"",
	    "if (Test-Path $cacheDir) { Remove-Item $cacheDir -Recurse -Force }"
	]
}
